{
  "name": "aliasist-platform",
  "version": "0.0.1",
  "private": true,
  "description": "Aliasist vNext — unified monorepo for the Aliasist Intelligence Suite",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
