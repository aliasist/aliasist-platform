{
  "name": "aliasist-platform",
  "version": "0.0.1",
  "private": true,
  "description": "Aliasist vNext — unified monorepo for the Aliasist Intelligence Suite",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "node -e \"console.log('lint: skipped (no ESLint tasks); static checks: pnpm typecheck')\"",
    "test:rag-smoke": "node scripts/rag/test-rag-smoke.mjs",
    "test:rag-embeddings": "node scripts/rag/test-rag-embeddings.mjs",
    "test:rag-index": "node scripts/rag/test-rag-index.mjs",
    "test:spacesist-rag-dry": "node scripts/rag/test-spacesist-documents.mjs",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
